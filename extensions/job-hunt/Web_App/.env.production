# Firebase Configuration
# These values are injected at build time via GitHub Secrets (CI/CD).
# Do NOT hardcode real credentials here — this file is committed to git.
# See: .github/workflows/deploy-job-hunt.yml for how secrets are passed.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Environment
VITE_ENV=production
