{
  "buildCommand": "rm -rf node_modules .next dist && npm install && npx vue-tsc -b && npx vite build",
  "outputDirectory": "dist",
  "nodeVersion": "20.x",
  "regions": ["iad1"],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}