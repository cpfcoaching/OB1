{
  "buildCommand": "npm install --force && ./node_modules/.bin/vue-tsc -b && ./node_modules/.bin/vite build",
  "outputDirectory": "dist",
  "nodeVersion": "20.x",
  "_cacheBuster": "2025-05-02T15:10:00Z",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}