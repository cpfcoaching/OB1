{
  "buildCommand": "./build.sh",
  "outputDirectory": "dist",
  "nodeVersion": "20.x",
  "env": {
    "BUILD_CACHE_BUSTER": "@now"
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}