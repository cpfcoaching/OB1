# Firebase Configuration
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-firebase-app-id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# MCP Server Configuration
VITE_JOB_HUNT_MCP_URL=your-job-hunt-mcp-url
VITE_OPEN_BRAIN_MCP_URL=your-open-brain-mcp-url

# Domain
VITE_DOMAIN=your-domain.com
VITE_API_BASE_URL=https://api.your-domain.com

# Environment
VITE_ENV=development

# Google Analytics 4
# Get this from: https://analytics.google.com/
# Format: G-XXXXXXXXXX (replace with your Measurement ID)
VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# LinkedIn Insight Tag
# Get this from: https://business.linkedin.com/marketing-solutions/linkedin-insight-tag
# This is your Partner ID (usually a 10-digit number)
VITE_LINKEDIN_PARTNER_ID=123456789
