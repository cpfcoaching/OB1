rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Resume collection - single user only
    match /resumes/personal {
      // Allow read/write only for authenticated users
      allow read, write: if request.auth != null;
    }

    // Resume versions subcollection
    match /resumes/personal/versions/{versionId} {
      allow read, write: if request.auth != null;
    }

    // Resume evaluations subcollection
    match /resumes/personal/evaluations/{evaluationId} {
      allow read, write: if request.auth != null;
    }

    // LinkedIn evaluations subcollection
    match /resumes/personal/linkedin_evaluations/{linkedinId} {
      allow read, write: if request.auth != null;
    }

    // User profile data (for future use)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // User preferences (for future use)
    match /users/{userId}/preferences/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
